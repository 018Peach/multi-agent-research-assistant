# ── Multi-Agent Research Assistant — environment template ────────────────────
# Copy this file to `.env` (same folder) and fill in your keys:
#     cp .env.example .env
# Settings are loaded from `.env` by pydantic-settings (see config.py).
# NEVER commit your real .env (it is git-ignored).

# ── Gemini (REQUIRED) ────────────────────────────────────────────────────────
# One or more Google AI Studio API keys, comma-separated. Multiple keys are
# rotated on rate-limit/quota (free-tier friendly); a single paid key also works.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEYS=your-gemini-key-1,your-gemini-key-2

# Model + output cap (defaults shown; usually leave as-is).
MODEL_NAME=gemini-3-flash-preview
MAX_OUTPUT_TOKENS=8192

# ── Web search & fetch (OPTIONAL) ────────────────────────────────────────────
# web_search tries providers in SEARCH_PROVIDER_ORDER. Tavily/Exa are skipped if
# their key is blank; Gemini's built-in Google Search is the keyless fallback, so
# search still works with no external keys. fetch_page (source verification by the
# critic) needs FIRECRAWL_API_KEY — without it, fetch_page is skipped and critic agent won't be able to verify claims.
TAVILY_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=
SEARCH_PROVIDER_ORDER=tavily,exa,gemini

# ── Behaviour / guardrails (OPTIONAL — defaults shown) ───────────────────────
MAX_SUBTASKS=3
MAX_RESEARCH_ITERATIONS=1
CONFIDENCE_THRESHOLD=0.7

# ── Per-agent bounds (OPTIONAL — defaults shown) ─────────────────────────────
PLAN_MAX_STEPS=4
PLAN_MAX_TOOL_CALLS=8
RESEARCH_MAX_STEPS=5
RESEARCH_MAX_TOOL_CALLS=10
CRITIC_MAX_STEPS=10
CRITIC_MAX_TOOL_CALLS=30
RECURSION_LIMIT=50

# ── Infra (OPTIONAL — defaults shown) ────────────────────────────────────────
REQUEST_TIMEOUT=60
# checkpoint DB path (runtime artifacts — DB + uploads — are kept under ./.runtime/)
DB_PATH=./.runtime/checkpoints.sqlite

# ── Cost estimation (OPTIONAL) ───────────────────────────────────────────────
# Per-million-token prices for the observability cost estimate. Leave blank to
# report token counts with $0.00 cost. (Gemini 3 Flash ≈ 0.50 in / 3.00 out.)
PRICE_INPUT_PER_M=0.5
PRICE_OUTPUT_PER_M=3.00
